{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./e2e-dist",
    "rootDir": ".",
    "types": ["node", "mocha", "@wdio/globals/types"],
    "lib": ["ES2020"]
  },
  "include": ["e2e/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-web", "dist-native"]
}
